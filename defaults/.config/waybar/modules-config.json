	"temperature": {
		"critical-threshold": 90,
		"format": "{icon} {temperatureC}¬∞C",
		"format-icons": [
			"пЛЙ",
			"пЛЙ",
			"пЛЙ"
		]
	},
	"custom/wvkbd": {
		"format": "у∞ММ ",
