{
	"backlight": {
		"interval": 2,
		"align": 0,
		"rotate": 0,
		"format": "{icon} {percent}%",
		"format-icons": [
			"оҺҚ",
			"оҸ“",
			"оҸ‘",
			"оҸҸ",
			"оҸҺ",
			"оҸҚ",
			"оҸҠ",
			"оҸҲ",
			"оҺӣ"
		],
		"on-click": "",
		"on-click-middle": "",
		"on-click-right": "",
		"on-update": "",
		"on-scroll-up": "light -A 5%",
		"on-scroll-down": "light -U 5%",
		"smooth-scrolling-threshold": 1
	},
	"ext/workspaces": {
		"format": "{name}",
		"on-click": "activate",
		"all-outputs": true,
		"sort-by-coordinates": false,
		"sort-by-number": true,
		"format-icons": {
			"1": "пҖ•",
			"2": "пү©",
			"3": "п„Ў",
			"4": "пҮ—",
			"5": "п„Ў",
			"6": "пҮ—",
			"7": "п„Ў",
			"8": "пҶ¶",
			"9": "п„Ў",
			"10": "п„ ",
			"focused": "пҶ’",
			"default": "п„ "
		}
	},
	"battery": {
		"interval": 60,
		"align": 0,
		"rotate": 0,
		"full-at": 100,
		"design-capacity": false,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "пғ§ {icon} {capacity}%",
		"format-plugged": "пҮҰ   {capacity}%",
		"format-alt": "{icon} {time}",
		"format-icons": [
			"у°Ғә",
			"у°Ғ»",
			"у°Ғј",
			"у°ҒҪ",
			"у°Ғҫ",
			"у°Ғҝ",
			"у°ӮҖ",
			"у°ӮҒ",
			"у°ӮӮ",
			"у°Ғ№"
		],
		"format-time": "{H}h {M}min",
		"tooltip": true
	},
	"clock": {
		"interval": 60,
		"align": 0,
		"rotate": 0,
		"tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
		"format": "у°Ҙ”  {:%H:%M}",
		"format-alt": "пҒі {:%a %b %d, %G}"
	},
	"custom/menu": {
		"format": "оӨғ",
		"tooltip": false,
		"on-click": "$HOME/.config/hypr/scripts/menu"
	},
	"custom/power": {
		"format": "пӨӨ",
		"tooltip": false,
		"on-click": "$HOME/.config/hypr/scripts/wlogout"
	},
	"disk": {
		"interval": 30,
		"format": "пҡ· FREE: {free}"
	},
	"mpd": {
		"interval": 2,
		"unknown-tag": "N/A",
		"format": "{stateIcon} {artist} - {title}",
		"format-disconnected": "пўү Disconnected",
		"format-paused": "{stateIcon} {artist} - {title}",
		"format-stopped": "Stopped пҠҚ",
		"state-icons": {
			"paused": "п…„",
			"playing": "пҠӢ"
		},
		"tooltip-format": "MPD (connected)",
		"tooltip-format-disconnected": "MPD (disconnected)",
		"on-click": "mpc toggle",
		"on-click-middle": "mpc prev",
		"on-click-right": "mpc next",
		"on-update": "",
		"on-scroll-up": "mpc seek +00:00:01",
		"on-scroll-down": "mpc seek -00:00:01",
		"smooth-scrolling-threshold": 1
	},
	"network": {
		"interval": 5,
		"format-wifi": "пҮ«  {essid}",
		"format-ethernet": "пӣҝ   {ipaddr}/{cidr}",
		"format-linked": "пӣҝ   {ifname} (No IP)",
		"format-disconnected": "пӘ©  Disconnected",
		"format-disabled": "пӘ©  Disabled",
		"format-alt": "пғҳ  {bandwidthUpBits} | пғ— {bandwidthDownBits}",
		"tooltip-format": "п”Ӯ  {ifname} via {gwaddr}"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-muted": "п‘Ұ Mute",
		"format-bluetooth": "пҠ“ {volume}% {format_source}",
		"format-bluetooth-muted": "пҠ“ Mute",
		"format-source": "п„° {volume}%",
		"format-source-muted": "п„ұ",
		"format-icons": {
			"headphone": "пҖҘ ",
			"hands-free": "пҹҸ",
			"headset": "пҹҚ ",
			"phone": "пӮ• ",
			"portable": "пӮ• ",
			"car": "пҶ№ ",
			"default": [
				"пҖҰ",
				"пҖ§ ",
				"пҖЁ "
			]
		},
		"scroll-step": 5.0,
		"on-click": "pactl -- set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-right": "pavucontrol",
		"smooth-scrolling-threshold": 1
	},
	"tray": {
		"icon-size": 20,
		"spacing": 10
	},
	"keyboard-state": {
		"numlock": true,
		"capslock": true,
		"format": "{name} {icon}",
		"format-icons": {
			"locked": "пҖЈ",
			"unlocked": "пӮң"
		}
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "у°ҲҲ ",
			"deactivated": "у°Ҳү "
		},
		"tooltip-format-activated": "Keep PC awake",
		"tooltip-format-deactivated": "PC will go to sleep"
	},
	"cpu": {
		"format": "п’ј  {usage}%",
		"tooltip": false
	},
	"memory": {
		"interval": 2,
		"format": "оүҰ  {}% "
	},
	"temperature": {
		"critical-threshold": 90,
		"format": "{icon} {temperatureC}В°C",
		"format-icons": [
			"пӢү",
			"пӢү",
			"пӢү"
		]
	},
	"custom/wvkbd": {
		"format": "у°ҢҢ ",
		"on-click": "bash ~/.config/waybar/scripts/wvkbd-toggle.sh"
	},
	"custom/displays": {
		"format": "рҹ–ө ",
		"on-click": "nwg-displays"
	},
	"custom/left-arrow": {
		"format": "оӮІ",
		"tooltip": false
	},
	"custom/right-arrow": {
		"format": "оӮ°",
		"tooltip": false
	},
	"custom/archicon": {
		"format": " пҢғ ",
		"tooltip": false
	},
	"custom/dunst": {
		"exec": "~/.config/waybar/scripts/dunst.sh",
		"on-click": "dunstctl set-paused toggle",
		"tooltip": false,
		"restart-interval": 1
	},
	"custom/light": {
		"format": "{icon} ",
		"format-source": "{icon} ",
		"tooltip": false,
		"on-click": "hyprctl hyprsunset gamma reset",
		"format-icons": [
			"у°ӣЁ"
		],
		"on-scroll-up": "bash ~/.config/waybar/scripts/hyprsunset_light_control.sh up",
		"on-scroll-down": "bash ~/.config/waybar/scripts/hyprsunset_light_control.sh down"
	},
	"custom/temperature": {
		"format": "{icon} ",
		"format-source": "{icon} ",
		"tooltip": false,
		"on-click": "hyprctl hyprsunset temperature reset",
		"format-icons": [
			"уұ©Ң"
		],
		"on-scroll-up": "bash ~/.config/waybar/scripts/hyprsunset_temp_control.sh up",
		"on-scroll-down": "bash ~/.config/waybar/scripts/hyprsunset_temp_control.sh down"
	}
}
