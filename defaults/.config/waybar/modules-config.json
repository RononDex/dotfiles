			"9": "пД°",
			"10": "пД†",
			"focused": "пЖТ",
			"default": "пД†"
		}
	},
	"battery": {
		"interval": 60,
		"align": 0,
		"rotate": 0,
		"full-at": 100,
		"design-capacity": false,
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "пГІ {icon} {capacity}%",
		"format-plugged": "пЗ¶   {capacity}%",
		"format-alt": "{icon} {time}",
		"format-icons": [
			"у∞БЇ",
			"у∞Бї",
			"у∞БЉ",
			"у∞Бљ",
			"у∞БЊ",
