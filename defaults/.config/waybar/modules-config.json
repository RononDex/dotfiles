		"format-disabled": "п™©  Disabled",
		"format-alt": "пГШ  {bandwidthUpBits} | пГЧ {bandwidthDownBits}",
		"tooltip-format": "пФВ  {ifname} via {gwaddr}"
	},
	"pulseaudio": {
