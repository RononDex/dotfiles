		"smooth-scrolling-threshold": 1
	},
	"tray": {
		"icon-size": 20,
		"spacing": 10
	},
	"keyboard-state": {
		"numlock": true,
		"capslock": true,
		"format": "{name} {icon}",
		"format-icons": {
