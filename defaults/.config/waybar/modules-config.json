	},
	"clock": {
		"interval": 60,
		"align": 0,
		"rotate": 0,
		"tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
		"format": "у∞•Ф  {:%H:%M}",
		"format-alt": "пБ≥ {:%a %b %d, %G}"
	},
	"custom/menu": {
		"format": "о§Г",
